{
  "zoomAccessToken": {
    "schema": {
      "protocol": "https",
      "method": "POST",
      "host": "zoom.us",
      "path": "/oauth/token",
      "headers": {
        "Authorization": "Basic <%= encode(context.basic_credentials) %>",
        "Content-Type": "application/x-www-form-urlencoded"
      }
    }
  },
  "zoomUserMe": {
    "schema": {
      "protocol": "https",
      "method": "GET",
      "host": "api.zoom.us",
      "path": "/v2/users/me",
      "headers": {
        "Authorization": "Bearer <%= context.access_token %>",
        "Content-Type": "application/json"
      }
    }
  }
}
